# Deny-all by default
*
.*

# Allowlist: repository metadata
!.gitignore
!VERSION
!LICENSE
!README.md
!CONTRIBUTING.md
!SECURITY.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md

# Images (README hero, etc.)
!assets/
!assets/**

# Testing (kind + scripts)
!testing/
!testing/**

# GitHub Actions
!.github/
!.github/workflows/
!.github/workflows/**

# Deployment tree
!Makefile
!run/
!run/**

# full-reset-example — local operator data (parent allowed by !run/** above)
run/examples/full-reset-example/.env
run/examples/full-reset-example/.probe-cache/
run/examples/full-reset-example/.logs/*
!run/examples/full-reset-example/.logs/.keep

# Optional local data placeholder
!data/
!data/.keep

# Generated noise
.DS_Store

# Local-only — Cursor rules, AGENTS.md, and IDE metadata (not committed; keep on this machine).
.cursor/
AGENTS.md
