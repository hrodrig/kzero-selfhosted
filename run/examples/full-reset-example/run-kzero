#!/bin/bash
# Run kzero against kzero-full-reset.sample.yml (host binary).
# Usage: ./run-kzero analyze | probe | down | up | reset
#        ./run-kzero --live reset   # mutates cluster (requires YES)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${ENV_FILE:-$SCRIPT_DIR/.env}"
# shellcheck source=lib/kubeconfig.sh
source "$SCRIPT_DIR/lib/kubeconfig.sh"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$ENV_FILE"
  set +a
fi
kzero_demo_apply_kubeconfig || true

KZERO_BIN="${KZERO_BIN:-kzero}"
CONFIG_FILE="${CONFIG_FILE:-$SCRIPT_DIR/kzero-full-reset.sample.yml}"
HELM_WORKSPACE="${HELM_WORKSPACE:-$SCRIPT_DIR/helm}"
LOGS_DIRECTORY="${LOGS_DIRECTORY:-$SCRIPT_DIR/.logs}"
RUN_MODE_OVERRIDE=""
KUBECONFIG_OVERRIDE=""
KZERO_COLOR_OVERRIDE=""
COMMAND=""
CONFIG_FOR_RUN=""
CONFIG_TEMP=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
log_ok() { echo -e "${GREEN}✅ $1${NC}"; }
log_warn() { echo -e "${YELLOW}⚠️  $1${NC}"; }
log_err() { echo -e "${RED}❌ $1${NC}"; }

usage() {
  cat <<EOF
Usage: $0 [OPTIONS] <analyze|probe|down|up|reset>

Options:
  --config-file PATH   Profile YAML (default: ./kzero-full-reset.sample.yml)
  --kubeconfig PATH    Sets KZERO_RUN_KUBECONFIG for this run
  --live               run.mode=live (confirmation required for down/up/reset)
  --dry-run            run.mode=dry-run
  --no-color           KZERO_COLOR=never
  --help, -h           This help

See README.md and run/docs/full-reset-validation.md (real cluster, namespace kzero-demo).
EOF
}

config_for_run() {
  echo "${CONFIG_FOR_RUN:-$CONFIG_FILE}"
}

helm_workspace_abs() {
  (cd "$HELM_WORKSPACE" && pwd)
}

patch_helm_workspace_in_config() {
  local in="$1" out="$2"
  local ws_abs
  ws_abs="$(helm_workspace_abs)"
  if grep -qE '^[[:space:]]*workspace:' "$in"; then
    sed -E "s|^([[:space:]]*workspace:)[[:space:]]*.*|\\1 \"${ws_abs}\"|" "$in" >"$out"
  else
    cp "$in" "$out"
  fi
}

prepare_config_for_run() {
  CONFIG_FOR_RUN="$CONFIG_FILE"
  if [[ -z "$RUN_MODE_OVERRIDE" && -z "$KZERO_COLOR_OVERRIDE" ]]; then
    patch_helm_workspace_in_config "$CONFIG_FILE" "${CONFIG_TEMP:=$(mktemp "${TMPDIR:-/tmp}/kzero-fr.XXXXXX.yaml")}"
    CONFIG_FOR_RUN="$CONFIG_TEMP"
    return 0
  fi
  CONFIG_TEMP="$(mktemp "${TMPDIR:-/tmp}/kzero-fr.XXXXXX.yaml")"
  local input="$CONFIG_FILE"
  if [[ -n "$RUN_MODE_OVERRIDE" ]]; then
    sed -E "s/^([[:space:]]*mode:)[[:space:]]*.*/\\1 \"${RUN_MODE_OVERRIDE}\"/" "$input" >"$CONFIG_TEMP"
    input="$CONFIG_TEMP"
  else
    cp "$CONFIG_FILE" "$CONFIG_TEMP"
    input="$CONFIG_TEMP"
  fi
  if [[ -n "$KZERO_COLOR_OVERRIDE" ]]; then
    local tmp_color
    tmp_color="$(mktemp "${TMPDIR:-/tmp}/kzero-fr-color.XXXXXX.yaml")"
    if grep -qE '^[[:space:]]*color:' "$input"; then
      sed -E "s/^([[:space:]]*color:)[[:space:]]*.*/\\1 \"${KZERO_COLOR_OVERRIDE}\"/" "$input" >"$tmp_color"
    else
      sed -E "/^([[:space:]]*mode:)/a\\
  color: \"${KZERO_COLOR_OVERRIDE}\"
" "$input" >"$tmp_color"
    fi
    mv "$tmp_color" "$CONFIG_TEMP"
    input="$CONFIG_TEMP"
  fi
  local tmp_ws
  tmp_ws="$(mktemp "${TMPDIR:-/tmp}/kzero-fr-ws.XXXXXX.yaml")"
  patch_helm_workspace_in_config "$input" "$tmp_ws"
  mv "$tmp_ws" "$CONFIG_TEMP"
  CONFIG_FOR_RUN="$CONFIG_TEMP"
}

cleanup_temp_config() {
  if [[ -n "${CONFIG_TEMP:-}" && -f "$CONFIG_TEMP" ]]; then
    rm -f "$CONFIG_TEMP"
  fi
}

effective_run_mode() {
  if [[ -n "$RUN_MODE_OVERRIDE" ]]; then
    echo "$RUN_MODE_OVERRIDE"
    return
  fi
  local mode
  mode="$(grep -E '^[[:space:]]*mode:' "$(config_for_run)" 2>/dev/null | head -1 \
    | sed -E 's/.*mode:[[:space:]]*"?([^"#]+)"?.*/\1/' | tr -d '"' | tr -d '[:space:]')"
  echo "${mode:-dry-run}"
}

run_kzero_cmd() {
  local subcmd="$1"
  local cfg="$2"
  local -a env_args=()
  local -a kzero_cmd=( "$KZERO_BIN" )
  if [[ -n "$RUN_MODE_OVERRIDE" ]]; then
    env_args+=(KZERO_RUN_MODE="$RUN_MODE_OVERRIDE")
  fi
  if [[ -n "$KUBECONFIG_OVERRIDE" ]]; then
    env_args+=(KZERO_RUN_KUBECONFIG="$KUBECONFIG_OVERRIDE")
  elif [[ -n "${KZERO_RUN_KUBECONFIG:-}" ]]; then
    env_args+=(KZERO_RUN_KUBECONFIG="$KZERO_RUN_KUBECONFIG")
  elif [[ -n "${KUBECONFIG:-}" ]]; then
    env_args+=(KZERO_RUN_KUBECONFIG="$KUBECONFIG")
  fi
  if [[ -n "${KZERO_LOG_LEVEL:-}" ]]; then
    kzero_cmd+=( --log-level "$KZERO_LOG_LEVEL" )
  fi
  kzero_cmd+=( "$subcmd" --config "$cfg" )
  if [[ ${#env_args[@]} -gt 0 ]]; then
    (cd "$SCRIPT_DIR" && env "${env_args[@]}" "${kzero_cmd[@]}")
  else
    (cd "$SCRIPT_DIR" && "${kzero_cmd[@]}")
  fi
}

warn_dry_run_no_cluster_change() {
  if [[ "$(effective_run_mode)" != "dry-run" ]]; then
    return 0
  fi
  echo ""
  log_warn "dry-run mode: the cluster is not changed (only [dry-run] lines in the log)."
  log_warn "To apply for real: $(basename "$0") --live ${COMMAND}"
  echo ""
}

require_live_confirm() {
  local cmd="$1"
  local cfg
  cfg="$(config_for_run)"
  echo ""
  log_warn "LIVE: command '${cmd}' will change the Kubernetes cluster shown below."
  echo ""
  if ! run_kzero_cmd target "$cfg"; then
    log_err "kzero target failed — fix kubeconfig."
    exit 1
  fi
  echo ""
  read -r -p "Type YES to continue against that cluster: " ans
  ans="${ans#"${ans%%[![:space:]]*}"}"
  ans="${ans%"${ans##*[![:space:]]}"}"
  if [[ "$ans" != "YES" ]]; then
    log_err "Aborted."
    exit 1
  fi
}

write_log_header() {
  local logfile="$1" subcmd="$2" cfg="$3"
  {
    echo "=== kzero full-reset-example ==="
    echo "time: $(date -Iseconds 2>/dev/null || date)"
    echo "command: kzero ${subcmd}"
    echo "config: ${cfg}"
    echo "run.mode: $(effective_run_mode)"
  } >>"$logfile"
  run_kzero_cmd target "$cfg" >>"$logfile" 2>&1 || true
  echo "---" >>"$logfile"
}

verify_prerequisites() {
  if ! command -v "$KZERO_BIN" >/dev/null 2>&1; then
    log_err "kzero not found (install v0.7.3+ from github.com/hrodrig/kzero)"
    exit 1
  fi
  if ! command -v kubectl >/dev/null 2>&1; then
    log_err "kubectl not found on PATH"
    exit 1
  fi
  if [[ ! -f "$CONFIG_FILE" ]]; then
    log_err "Config not found: $CONFIG_FILE"
    exit 1
  fi
  if [[ "$COMMAND" != "analyze" ]]; then
    if ! command -v helm >/dev/null 2>&1; then
      log_err "helm not found on PATH (required for release.* / infra_probe)"
      exit 1
    fi
    if [[ ! -d "$HELM_WORKSPACE" ]]; then
      log_err "Helm workspace missing: $HELM_WORKSPACE"
      exit 1
    fi
  fi
}

run_kzero() {
  local subcmd="$1"
  mkdir -p "$LOGS_DIRECTORY"
  local logfile="$LOGS_DIRECTORY/kzero-${subcmd}-$(date +%Y%m%d-%H%M%S).log"
  local cfg
  cfg="$(config_for_run)"
  log_info "kzero $subcmd --config $cfg (log: $logfile)"
  : >"$logfile"
  write_log_header "$logfile" "$subcmd" "$cfg"
  run_kzero_cmd "$subcmd" "$cfg" 2>&1 | tee -a "$logfile"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --config-file) CONFIG_FILE="$2"; shift 2 ;;
    --kubeconfig) KUBECONFIG_OVERRIDE="$2"; shift 2 ;;
    --live) RUN_MODE_OVERRIDE="live"; shift ;;
    --dry-run) RUN_MODE_OVERRIDE="dry-run"; shift ;;
    --no-color) KZERO_COLOR_OVERRIDE="never"; shift ;;
    analyze|probe|down|up|reset)
      if [[ -n "$COMMAND" ]]; then
        log_err "Only one kzero command per invocation"
        exit 1
      fi
      COMMAND="$1"
      shift
      ;;
    *)
      log_err "Unknown argument: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ -z "$COMMAND" ]]; then
  usage
  exit 1
fi

verify_prerequisites
trap cleanup_temp_config EXIT
prepare_config_for_run

if [[ "$RUN_MODE_OVERRIDE" == "live" && "$COMMAND" != "analyze" ]]; then
  require_live_confirm "$COMMAND"
fi

if [[ "$COMMAND" != "analyze" ]]; then
  warn_dry_run_no_cluster_change
fi

log_info "Starting full-reset-example at $(date); run.mode=$(effective_run_mode)"
run_kzero "$COMMAND"

if [[ "$COMMAND" == "reset" && "$(effective_run_mode)" == "live" ]]; then
  log_ok "reset completed — run ./run-kzero analyze to verify plan"
fi
