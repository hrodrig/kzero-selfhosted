# Copy: cp env.example .env  (local secrets — excluded by repo .gitignore)
#
# Target a lab/staging cluster only. Never point at production.
#
# Kubeconfig: leave KUBECONFIG unset to use kubectl defaults (~/.kube/config + current context).
# Uncomment only to override:
# export KUBECONFIG="$HOME/.kube/config"
# export KZERO_RUN_KUBECONFIG="$KUBECONFIG"

export KZERO_BIN="${KZERO_BIN:-kzero}"
export KZERO_CLIENT_ID="${KZERO_CLIENT_ID:-kzero-demo}"
export KZERO_DEMO_NAMESPACE="${KZERO_DEMO_NAMESPACE:-kzero-demo}"

export KZERO_RUN_MODE="${KZERO_RUN_MODE:-dry-run}"
export KZERO_RUN_TIMEOUT="${KZERO_RUN_TIMEOUT:-45m}"
export KZERO_RUN_OPERATION_TIMEOUT="${KZERO_RUN_OPERATION_TIMEOUT:-15m}"
export KZERO_RUN_EXECUTION="${KZERO_RUN_EXECUTION:-native}"
export KZERO_RUN_COLOR="${KZERO_RUN_COLOR:-always}"
export KZERO_RUN_PROBE_CACHE_DIR="${KZERO_RUN_PROBE_CACHE_DIR:-./.probe-cache}"

# Optional Slack (live pipelines) — see run/docs/notifications-full-reset.md
# export KZERO_NOTIFY_SLACK_ENABLED=true
# export KZERO_NOTIFY_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/…"

export CONFIG_FILE="${CONFIG_FILE:-kzero-full-reset.sample.yml}"
export ENV_FILE="${ENV_FILE:-.env}"
export LOGS_DIRECTORY="${LOGS_DIRECTORY:-./.logs}"
