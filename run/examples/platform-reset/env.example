# Platform reset — copy to .env and edit (do not commit).
# run-kzero sources .env automatically when present.

export KUBECONFIG="${KUBECONFIG:-$HOME/.kube/config}"
export KZERO_RUN_KUBECONFIG="${KZERO_RUN_KUBECONFIG:-$KUBECONFIG}"

export KZERO_BIN="${KZERO_BIN:-kzero}"
export KZERO_CLIENT_ID="${KZERO_CLIENT_ID:-platform-reset-lab-v1}"

export KZERO_RUN_MODE="${KZERO_RUN_MODE:-dry-run}"
export KZERO_RUN_TIMEOUT="${KZERO_RUN_TIMEOUT:-45m}"
export KZERO_RUN_OPERATION_TIMEOUT="${KZERO_RUN_OPERATION_TIMEOUT:-15m}"
export KZERO_RUN_EXECUTION="${KZERO_RUN_EXECUTION:-native}"
export KZERO_RUN_COLOR="${KZERO_RUN_COLOR:-always}"
export KZERO_RUN_PROBE_CACHE_DIR="${KZERO_RUN_PROBE_CACHE_DIR:-./.probe-cache}"

export CONFIG_FILE="${CONFIG_FILE:-kzero-platform-reset.sample.yml}"
export HELM_WORKSPACE="${HELM_WORKSPACE:-./helm}"
export LOGS_DIRECTORY="${LOGS_DIRECTORY:-./.logs}"

# Optional: private OCI mirror (uncomment and set in profile helm.registries[] too)
# export HELM_REGISTRY_HOST="${HELM_REGISTRY_HOST:-registry.example.com}"
# export HELM_REGISTRY_USER="${HELM_REGISTRY_USER:-pull-user}"
# export HELM_REGISTRY_PASSWORD="${HELM_REGISTRY_PASSWORD:-FIXME}"

# export KZERO_LOG_LEVEL=debug
